{
  "name": "geoplanet",
  "version": "1.0.0",
  "description": "GeoPlanet - Fullstack Monorepo",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "prepare": "husky install"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "apps/web/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @geoplanet/web type-check",
      "pnpm --filter @geoplanet/web lint"
    ],
    "apps/server/**/*.ts": [
      "pnpm --filter @geoplanet/server type-check",
      "pnpm --filter @geoplanet/server lint"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "turbo": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
